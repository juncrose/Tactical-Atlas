{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tactical-atlas.org/schemas/battle.schema.json",
  "title": "Battle",
  "description": "한 전투에 대한 모든 데이터. 새 전투를 추가하려면 이 스키마를 만족해야 합니다.",
  "type": "object",
  "required": ["id", "name", "name_en", "era", "year", "date_display", "coords", "sides", "tactics", "significance", "description"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_[0-9]{4}$",
      "description": "고유 ID. 형식: 소문자_이름_연도 (예: tannenberg_1914)"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "description": "한국어 이름"
    },
    "name_en": {
      "type": "string",
      "minLength": 2,
      "description": "영어 이름 (위키피디아 표제어와 일치 권장)"
    },
    "era": {
      "type": "string",
      "enum": ["ww1", "interwar", "ww2", "korean_war", "cold_war", "modern"],
      "description": "시대 분류. eras.json에 정의됨"
    },
    "year": {
      "type": "integer",
      "minimum": 1886,
      "maximum": 2100,
      "description": "주요 연도. CShapes 호환을 위해 1886년 이후만 허용"
    },
    "year_decimal": {
      "type": "number",
      "description": "타임라인 정렬용 소수 표현 (예: 1914.65 = 1914년 8월)"
    },
    "date_display": {
      "type": "string",
      "description": "사용자에게 보여줄 날짜 문자열"
    },
    "coords": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2,
      "description": "[위도, 경도]. 전투의 대표 좌표"
    },
    "sides": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["name", "commander", "troops", "casualties", "color", "victor", "symbol"],
        "properties": {
          "name": { "type": "string", "description": "교전 세력 이름" },
          "commander": { "type": "string", "description": "주요 지휘관" },
          "troops": { "type": "integer", "minimum": 0, "description": "병력 수" },
          "casualties": { "type": "integer", "minimum": 0, "description": "사상자 수" },
          "color": {
            "type": "string",
            "enum": ["blue", "red", "un", "us", "german", "japanese", "soviet", "rok", "kpa", "pva", "british", "french"],
            "description": "지도상 색상 그룹"
          },
          "victor": { "type": "boolean", "description": "승자 여부" },
          "symbol": {
            "type": "string",
            "description": "NATO APP-6 군 기호 타입 (예: infantry, armor_combined)"
          }
        }
      }
    },
    "tactics": {
      "type": "array",
      "minItems": 1,
      "description": "이 전투에서 사용된 핵심 전술 (보통 2-4개)",
      "items": {
        "type": "object",
        "required": ["ko", "en", "desc"],
        "properties": {
          "ko": { "type": "string", "description": "전술 한국어 이름" },
          "en": { "type": "string", "description": "전술 영문 (군사용어 정식 표기)" },
          "desc": { "type": "string", "description": "전술 설명 (1-2문장)" }
        }
      }
    },
    "significance": {
      "type": "string",
      "minLength": 50,
      "description": "전쟁사적 의의. <strong> 태그 사용 가능"
    },
    "description": {
      "type": "string",
      "minLength": 80,
      "description": "전투 경과 요약"
    },
    "influenced_by": {
      "type": "array",
      "items": { "type": "string" },
      "description": "이 전투에 영향을 준 다른 전투의 ID 목록"
    },
    "influences": {
      "type": "array",
      "items": { "type": "string" },
      "description": "이 전투가 영향을 준 다른 전투의 ID 목록"
    },
    "has_simulation": {
      "type": "boolean",
      "description": "simulations/{id}.json 파일이 존재하는지 여부"
    },
    "sources": {
      "type": "array",
      "description": "참고 문헌. 최소 1개 이상 권장 (review_status가 'reviewed' 이상이면 필수)",
      "items": {
        "type": "object",
        "required": ["type", "citation"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["book", "paper", "archive", "official_history", "web"]
          },
          "citation": { "type": "string", "minLength": 10 },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "wikidata_id": {
      "type": ["string", "null"],
      "pattern": "^Q[0-9]+$",
      "description": "위키데이터 엔티티 ID (예: Q156534)"
    },
    "wikipedia": {
      "type": "object",
      "properties": {
        "ko": { "type": ["string", "null"], "description": "한국어 위키피디아 URL (한글 허용)" },
        "en": { "type": ["string", "null"], "description": "영어 위키피디아 URL" }
      }
    },
    "contributors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "GitHub 사용자명 목록 (자동 갱신)"
    },
    "last_reviewed": {
      "type": ["string", "null"],
      "format": "date",
      "description": "마지막 검토일 (YYYY-MM-DD)"
    },
    "review_status": {
      "type": "string",
      "enum": ["community", "reviewed", "verified"],
      "description": "community = 누구나 편집 가능 / reviewed = 메인테이너 검토 완료 / verified = 출처 2개 이상 + 메인테이너 + 도메인 전문가 승인"
    }
  }
}
